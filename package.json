{
  "name": "takeoff-protocol",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:client": "bun run --filter @takeoff/client dev",
    "dev:server": "bun run --filter @takeoff/server dev",
    "build": "bun run --filter '*' build",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "husky": "^9.1.7",
    "typescript": "^5.9.3"
  }
}
